{
  "compilerOptions": {
    "target": "ES2020",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],

    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  },

  "include": [
    "src",
    "prisma.config.ts"
  ]
}